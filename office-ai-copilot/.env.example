# ───────────────────────────────────────────────
# Office AI Copilot — Ortam Değişkenleri
# Bu dosyayı `.env` olarak kopyala ve değerleri doldur.
# `.env` ASLA commit edilmez (.gitignore'da).
# ───────────────────────────────────────────────

# Claude API (zorunlu)
# https://console.anthropic.com/settings/keys adresinden al
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# Model seçimleri (varsayılanlar maliyet-optimize)
# Triyaj/sınıflandırma için ucuz Haiku, rapor/özet için Sonnet
MODEL_FAST=claude-haiku-4-5
MODEL_SMART=claude-sonnet-4-6

# Google Workspace (Yol B - Python scriptleri için)
# OAuth credentials.json yolu (docs/SETUP.md'ye bak)
GOOGLE_CREDENTIALS_PATH=./credentials.json
GOOGLE_TOKEN_PATH=./token.json

# Çıktı hedefleri (opsiyonel)
GOOGLE_SHEET_ID=                 # Toplantı notları / rapor verisi için Sheet ID
REPORT_RECIPIENT_EMAIL=          # Haftalık raporun gönderileceği adres

# Davranış ayarları
AUTO_SEND=false                  # true yaparsan email/davet otomatik gönderilir (DİKKAT)
TIMEZONE=Europe/Istanbul
